# When true and public/index.html exists, / shows that file instead of the Laravel home.
TEMPORARY_STATIC_HOME=false

# VUVAA API Configuration
VUVAA_LIVE_URL=https://verificationservice.vuvaa.com/NIN_Validation
VUVAA_USERNAME=
VUVAA_PASSWORD=
VUVAA_ENCRYPTION_KEY=
VUVAA_ENCRYPTION_IV=

# Payment gateways (optional; also configurable in Admin → API Keys / Payment Gateway row JSON)
# Flutterwave — used with Admin keys if DB fields are empty
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=
# Monnify — virtual accounts require MONNIFY_CONTRACT_CODE as well as API + secret.
# Use MONNIFY_SANDBOX=true with test keys (hits sandbox.monnify.com). Clear custom
# MONNIFY_ENDPOINT_* in Admin if they still point at production while using sandbox keys.
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=
MONNIFY_SANDBOX=false
# Paystack — secret used for dedicated virtual accounts (optional if only in Admin)
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
# PayVessel reserved accounts (virtual account reserve URL + key from PayVessel dashboard)
PAYVESSEL_API_KEY=
PAYVESSEL_ENDPOINT=
PAYVESSEL_BUSINESS_ID=
